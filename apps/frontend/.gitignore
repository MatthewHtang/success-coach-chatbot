####################
# Standard Node.js .gitignore
####################

# dependencies
**/node_modules
.pnp
.pnp.js

# testing
**/coverage

# next.js build output
**/.next/
**/out/

# production build
**/build

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files (do NOT commit secrets)
.env*.local
.env

# vercel deployment metadata
.vercel

# typescript incremental compilation cache
*.tsbuildinfo
